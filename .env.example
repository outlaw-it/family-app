# Copy this file to .env and fill in the keys for whichever cloud providers you want to use.
# A local provider (Ollama / LM Studio) needs no key at all.
#
#   cp .env.example .env
#
# Never commit .env — it is git-ignored.

# ── Database (Supabase Postgres) ────────────────────────────────────────────
# REQUIRED. Use the Supabase connection POOLER string (Supavisor), NOT the direct
# 5432 one — serverless/Workers need the pooler. In the Supabase dashboard:
#   Project → Connect → "Connection pooling" → Transaction mode  (host ends in
#   ...pooler.supabase.com, port 6543). The app sets prepare:false for this mode.
#
# Format:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# In production set this with:  wrangler secret put DATABASE_URL
DATABASE_URL=

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Azure OpenAI — key + endpoint from the Azure portal "Keys & Endpoint" page.
# AZURE_OPENAI_BASE_URL must end in /openai/v1 (a trailing /responses or
# /chat/completions is stripped automatically). AZURE_OPENAI_MODEL is your DEPLOYMENT name.
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=https://your-resource.services.ai.azure.com/openai/v1
# AZURE_OPENAI_MODEL=gpt-5.5

# Optional: point the "Local" provider at an OpenAI-compatible server.
# These set the DEFAULTS shown in Settings (you can still change them in the UI).
#
#   Ollama (same machine):     http://localhost:11434/v1
#   LM Studio (same machine):  http://localhost:1234/v1
#   LM Studio on your network: http://<that-machine-ip>:1234/v1   (enable "Serve on Local Network")
#
# The /v1 is added automatically if you leave it off, so the address LM Studio shows
# as "Reachable at" works as-is. Set LOCAL_MODEL to the exact model identifier shown
# in LM Studio (e.g. qwen/qwen3.6-27b).
#
# LOCAL_BASE_URL=http://192.168.10.214:1234/v1
# LOCAL_MODEL=qwen/qwen3.6-27b
